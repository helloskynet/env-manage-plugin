{
  "name": "env-plugin-root",
  "version": "0.5.6",
  "private": true,
  "description": "A dev env plugin that integrates an Express server with request proxying capabilities.",
  "keywords": [
    "proxy",
    "devServer",
    "Development environment management",
    "webpack-plugin",
    "rollup-plugin",
    "vite-plugin"
  ],
  "bin": {
    "envm": "bin/index.js"
  },
  "main": "./dist/Plugin.js",
  "types": "./dist/types.d.ts",
  "exports": {
    ".": {
      "import": "./dist/Plugin.js",
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "clean": "pnpm store prune && pnpm dlx rimraf -g **/node_modules",
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm --filter env-plugin --filter client build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/{server,client}/**/*.{ts,vue,js}": [
      "eslint --fix"
    ]
  },
  "author": "lcn",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@eslint/json": "^1.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.16.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "nodemon": "^3.1.9",
    "syncpack": "^14.0.0",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.3.1"
  },
  "bugs": {
    "url": "https://github.com/lumos934/env-plugin/issues"
  },
  "homepage": "https://github.com/lumos934/env-plugin#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lumos934/env-plugin.git"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "bin/index.js",
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ]
}
